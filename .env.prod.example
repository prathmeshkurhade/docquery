# --- Docker Hub ---
DOCKERHUB_USERNAME=yourdockerhubusername

# --- PostgreSQL ---
POSTGRES_USER=ragapp
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=ragapp
DATABASE_URL=postgresql+asyncpg://ragapp:change-this-to-a-strong-password@postgres:5432/ragapp

# --- Vector DB (internal docker network, no port needed) ---
QDRANT_URL=http://qdrant:6333

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Gemini ---
GEMINI_API_KEY=your-gemini-key

# --- Cohere ---
COHERE_API_KEY=your-cohere-key

# --- Auth ---
JWT_SECRET=generate-a-long-random-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
